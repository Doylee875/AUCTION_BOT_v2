# ============================================================
#  STALCRAFT API — шаблон переменных окружения
#  Скопируйте файл: cp .env.example .env
#  Заполните обязательные поля (помечены *REQUIRED*)
# ============================================================


# ------------------------------------------------------------
# API
# ------------------------------------------------------------
BASE_URL=https://eapi.stalzone.net
REGION=RU                          # RU | EU


# ------------------------------------------------------------
# OAuth *REQUIRED*
# Первая пара клиентских учётных данных
# ------------------------------------------------------------
CLIENT_ID=
CLIENT_SECRET=

# Вторая пара (опционально, для параллельных запросов)
CLIENT_ID2=
CLIENT_SECRET2=


# ------------------------------------------------------------
# Внешние сервисы
# ------------------------------------------------------------
GITHUB_TOKEN=                      # Для синхронизации каталога предметов


# ------------------------------------------------------------
# Хранилище
# ------------------------------------------------------------
DB_PATH=data/FREAK.db
ICONS_DIR=data/icons


# ------------------------------------------------------------
# Фильтры предметов
# Значения через запятую, например: id1,id2,id3
# ------------------------------------------------------------
EXCLUDE_IDS_FILTER=
EXCLUDE_CATEGORIES_FILTER=
INCLUDE_IDS_FILTER=
INCLUDE_CATEGORIES_FILTER=


# ------------------------------------------------------------
# Уведомления — Telegram
# ------------------------------------------------------------
TG_BOT_TOKEN=                      # Токен бота от @BotFather
TG_CHAT_ID=                        # ID чата / канала для алертов


# ------------------------------------------------------------
# Уведомления — Discord
# ------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=


# ------------------------------------------------------------
# Бизнес-логика аукциона
# ------------------------------------------------------------
AUCTION_COMMISSION=0.05            # Комиссия аукциона (доля, 0.05 = 5 %)


# ------------------------------------------------------------
# Логирование
# ------------------------------------------------------------
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s


# ------------------------------------------------------------
# Зарезервировано (закомментировано в коде, для будущих релизов)
# ------------------------------------------------------------
# REQUEST_TIMEOUT=30.0
# MAX_RETRIES=3
# RETRY_DELAY=1.0
# PARALLEL_CLIENTS=2
# REQUEST_DELAY=0.2
# RATE_LIMIT_RPS=
# LOTS_POLL_INTERVAL=120
# LOTS_DISCOUNT_THRESHOLD=0.15
# LOTS_ALERT_COOLDOWN_SEC=600
# LOTS_VOLATILITY_SCALE_THR=0.30
# HISTORY_MAX_AGE_DAYS=30
